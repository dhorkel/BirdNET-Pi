<icecast>
  <limits>
    <clients>100</clients>
    <sources>2</sources>
    <queue-size>524288</queue-size>
    <client-timeout>30</client-timeout>
    <header-timeout>15</header-timeout>
    <source-timeout>10</source-timeout>
  </limits>

  <authentication>
    <source-password>ICECAST_PWD_PLACEHOLDER</source-password>
    <relay-password>ICECAST_PWD_PLACEHOLDER</relay-password>
    <admin-user>birdnet</admin-user>
    <admin-password>ICECAST_PWD_PLACEHOLDER</admin-password>
  </authentication>

  <hostname>localhost</hostname>

  <listen-socket>
    <port>8000</port>
    <bind-address>127.0.0.1</bind-address>
  </listen-socket>

  <shoutcast-mount>/stream</shoutcast-mount>

  <paths>
    <logdir>/var/log/icecast2</logdir>
    <webroot>/usr/share/icecast2/web</webroot>
    <adminroot>/usr/share/icecast2/admin</adminroot>
  </paths>

  <logging>
    <accesslog>/dev/null</accesslog>
    <errorlog>stderr</errorlog>
    <loglevel>3</loglevel>
  </logging>
</icecast>
